# @type string
# The root URL of the site (no trailing slash)
BASHKIM_COM_BASE_HREF="{{ baseHref }}"

# @type string
# The API key for GitHub
GITHUB_TOKEN="{{ githubToken }}"

# @type string
# The access token for prismic.io
PRISMICIO_ACCESS_TOKEN="{{ prismicioAccessToken }}"

# @type boolean
# Whether or not to enable MSW: mock service worker
MSW_ENABLED="{{#if mswEnabled}}1{{else}}0{{/if}}"
