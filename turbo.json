{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env", "package.json", "package-lock.json"],
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },

    "codegen": {
      "env": ["TS_NODE_TRANSPILE_ONLY"],
      "inputs": ["src/**/*.ts", "!**/gql/**/*.ts"],
      "outputs": ["**/gql/**/*.ts"]
    },

    "codegen:dev": {
      "cache": false,
      "persistent": true
    },

    "dev": {
      "cache": false,
      "persistent": true
    },

    "lint": {
      "dependsOn": ["codegen"],
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.mjs", "**/*.js"]
    },

    "storybook:build": {
      "dependsOn": ["codegen"],
      "outputs": ["storybook-static/"]
    },

    "test": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    }
  }
}
