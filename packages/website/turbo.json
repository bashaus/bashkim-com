{
  "$schema": "https://v2-9-5.turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^compile"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "BASHKIM_COM_BASE_HREF",
        "BASHKIM_COM_GOOGLE_ANALYTICS_ENABLED",
        "BASHKIM_COM_GOOGLE_ANALYTICS_MEASUREMENT_ID",
        "PRISMICIO_ACCESS_TOKEN"
      ]
    },

    "test": {
      "dependsOn": ["^compile"]
    }
  }
}
