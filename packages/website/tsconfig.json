{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["@bashkim-com/tsconfig/tsconfig.base.json"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"]
}
