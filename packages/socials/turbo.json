{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "codegen": {
      "env": ["GITHUB_TOKEN"]
    },

    "compile": {
      "dependsOn": ["codegen"],
      "env": ["GITHUB_TOKEN"]
    },

    "lint": {
      "dependsOn": ["codegen"]
    },

    "test": {
      "dependsOn": ["codegen"]
    }
  }
}
