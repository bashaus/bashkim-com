    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bashkim-com/eslint": "*",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@parcel/watcher": "^2.5.6",
    "@types/lodash.groupby": "^4.6.9",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.4.0",
    "vitest": "^4.1.2"
  }
