{
  "name": "@bashkim-com/socials",
  "version": "0.0.0",
  "exports": {
    ".": "./src/index.ts",
    "./github": "./src/github/index.ts",
    "./medium": "./src/medium/index.ts",
    "./stack-overflow": "./src/stack-overflow/index.ts"
  },
  "main": "./src/index.ts",
  "scripts": {
    "codegen": "TS_NODE_TRANSPILE_ONLY=true graphql-codegen --config codegen.ts",
